generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Member {
  id           String   @id @default(uuid())
  vorname      String
  nachname     String
  foto         String?
  geburtsdatum DateTime?
  tarif        Tarife   @default(BASIC)
  status       Status   @default(AKTIV)
  ist_gesperrt Boolean  @default(false)
  gesperrt_bis DateTime?
  altvertrag   Boolean  @default(false)
  createdAt    DateTime @default(now())
  bookings     Booking[]
}

model Course {
  id            String     @id @default(uuid())
  titel         String
  raum          Raum
  max_plaetze   Int
  trainer_id    String
  start_zeit    DateTime
  dauer_minuten Int
  status        KursStatus @default(GEPLANT)
  bookings      Booking[]
}

model Booking {
  id                    String         @id @default(uuid())
  mitglied_id           String
  member                Member         @relation(fields: [mitglied_id], references: [id])
  kurstermin_id         String
  course                Course         @relation(fields: [kurstermin_id], references: [id])
  status                BuchungsStatus @default(GEBUCHT)
  warteliste_index      Int?
  nachrueck_zeitstempel DateTime?
}

enum Tarife { ONLINE BASIC PLUS PREMIUM }
enum Status { AKTIV PAUSIERT GEKUENDIGT ZAHLUNG_AUSSTEHEND }
enum Raum { GROSSER_KURSRAUM SPINNING_RAUM FREIHANTELBEREICH OUTDOOR }
enum KursStatus { GEPLANT STORNIERT }
enum BuchungsStatus { GEBUCHT WARTELISTE ANWESEND NO_SHOW ZU_SPAET_STORNIERT }